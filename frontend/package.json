{
  "name": "fly-edu-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:release": "node scripts/ensure-android-api-env.mjs && npm run build",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:sync:release": "node scripts/ensure-android-api-env.mjs && npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:live": "node scripts/dev-android.mjs",
    "android:aab:release": "npm run cap:sync:release && cd android && gradlew bundleRelease -x test -x lint"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/local-notifications": "^8.0.2",
    "@tanstack/react-query": "^5.45.0",
    "axios": "^1.7.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0",
    "tailwind-merge": "^2.3.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.4.5",
    "vite": "^5.3.3"
  }
}

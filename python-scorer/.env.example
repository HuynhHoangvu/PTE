# Copy this file to .env and set values locally. Do NOT put real keys in .env.example (this file is committed).
#
# Railway: Project → your service → Variables → add GEMINI_API_KEY (same name). Redeploy after saving.
# Local:  python-scorer/.env with GEMINI_API_KEY=... (Fly_PTE/.gitignore already ignores .env)

GEMINI_API_KEY=

# Whisper model size: tiny, base, small, medium, large
# On CPU (recommended): tiny or base for speed
# On GPU (recommended): small, medium for quality
# Auto-detected: tiny on CPU, small on GPU if not specified
WHISPER_MODEL=tiny

# HIW backfill /find-incorrect-words: mac dinh canh tu (Whisper vs content) bang difflib, khong bat buoc Gemini.
# HIW_FIND_WORDS_USE_GEMINI=1  — chi dung Gemini (nhu cu)
# HIW_FIND_WORDS_DIFF_ONLY=1   — chi difflib, khong goi Gemini (diff rong thi tra mang rong)

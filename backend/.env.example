# Database — local
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=yourpassword
DB_DATABASE=fly_edu

# Railway / cloud: dat day du URL (Nest bat ssl khi co DATABASE_URL). Script Node van can DB_*:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Đồng bộ local -> Railway (pg_dump .sql + psql): xem scripts/sync-local-to-railway.ps1
#   LOCAL_DATABASE_URL=postgresql://postgres:...@127.0.0.1:5432/fly_edu
#   RAILWAY_DATABASE_URL=postgresql://postgres:...@HOST:PORT/railway
# DB_HOST=... DB_PORT=... DB_USERNAME=... DB_PASSWORD=... DB_DATABASE=...

# JWT
JWT_SECRET=fly_edu_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Gemini (chấm điểm / transcription fallback trong Nest — xem ai-scoring.service.ts)
GEMINI_API_KEY=

# Python scorer (FastAPI, repo python-scorer): Whisper + POST /score, /transcribe, ...
# Railway public: https://<service-py>.up.railway.app (không có / ở cuối)
# Hoặc private nội bộ cùng project: http://<private-hostname>:8001 (port theo container Py)
PYTHON_SCORER_URL=http://127.0.0.1:8001

# App
PORT=3000
NODE_ENV=development
# Web + nhiều origin (phẩy). Backend còn cho phép thêm WebView Capacitor (localhost) trong code.
FRONTEND_URL=http://localhost:5173

# Google Cloud Storage (production audio upload)
GCS_PROJECT_ID=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=
GCS_BUCKET_NAME=

# Đăng nhập Google (GIS): OAuth 2.0 Client ID kiểu **Web application** (Google Cloud Console).
# Authorized JavaScript origins: http://localhost:5173, https://your-frontend.railway.app
GOOGLE_CLIENT_ID=
